<Window x:Class="BYOVDMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BYOVD Monitor — vulnerable driver detector"
        Height="720" Width="1040"
        MinHeight="560" MinWidth="880"
        WindowStartupLocation="CenterScreen"
        Background="#FF161A1F"
        TextOptions.TextFormattingMode="Display"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <!-- Конвертер bool -> Visibility для пометки "вложенные папки" -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Цвета темы -->
        <SolidColorBrush x:Key="Fg" Color="#FFE6E9EE"/>
        <SolidColorBrush x:Key="FgDim" Color="#FF9AA4B2"/>
        <SolidColorBrush x:Key="Panel" Color="#FF1E242C"/>
        <SolidColorBrush x:Key="PanelBorder" Color="#FF2C3540"/>
        <SolidColorBrush x:Key="Accent" Color="#FF3D8BFD"/>

        <!-- Базовый стиль кнопок -->
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Fg}"/>
            <Setter Property="Background" Value="#FF2A323C"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF35404C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="BorderBrush" Value="#FF2C6FD6"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Fg}"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Fg}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF11151A"/>
            <Setter Property="Foreground" Value="{StaticResource Fg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="CaretBrush" Value="{StaticResource Fg}"/>
        </Style>

        <!-- Анимация мигания ореола лампы при тревоге -->
        <Storyboard x:Key="BlinkStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="LampGlow"
                             Storyboard.TargetProperty="Opacity"
                             From="0.95" To="0.15" Duration="0:0:0.55"/>
        </Storyboard>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и управление базой -->
        <Border Grid.Row="0" Background="{StaticResource Panel}" BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="1" CornerRadius="6" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="BYOVD Monitor" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock x:Name="ListStatusText" Margin="0,2,0,0"
                               Foreground="{StaticResource FgDim}"
                               Text="Hash list not loaded"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="DownloadButton" Content="Download list"
                            Style="{StaticResource AccentButton}" Click="OnDownloadClick" Margin="0,0,8,0"/>
                    <Button x:Name="CheckUpdateButton" Content="Check for updates" Click="OnCheckUpdateClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Лампа-индикатор и панель папок -->
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Индикатор -->
            <Border Grid.Column="0" Background="{StaticResource Panel}" BorderBrush="{StaticResource PanelBorder}"
                    BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,12,0">
                <StackPanel>
                    <Grid Height="180" Width="180" HorizontalAlignment="Center">
                        <Ellipse x:Name="LampGlow" Width="170" Height="170" Opacity="0.5">
                            <Ellipse.Effect>
                                <BlurEffect Radius="42"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Ellipse x:Name="LampGlass" Width="118" Height="118" Stroke="#FF0B0E12" StrokeThickness="2"/>
                        <Ellipse Width="40" Height="40" Margin="0,28,40,0"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.35">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                    </Grid>
                    <TextBlock x:Name="StatusText" Text="Idle" FontSize="18" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    <TextBlock x:Name="StatusSubText" Text="Monitoring not running"
                               Foreground="{StaticResource FgDim}" HorizontalAlignment="Center"
                               TextAlignment="Center" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    <Button x:Name="ClearAlertButton" Content="Clear alert" Margin="0,14,0,0"
                            Click="OnClearAlertClick" IsEnabled="False"/>
                </StackPanel>
            </Border>

            <!-- Папки -->
            <Border Grid.Column="1" Background="{StaticResource Panel}" BorderBrush="{StaticResource PanelBorder}"
                    BorderThickness="1" CornerRadius="6" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Monitored folders" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="FolderPathBox" Grid.Column="0" VerticalContentAlignment="Center"/>
                        <Button Grid.Column="1" Content="Browse" Margin="8,0,0,0" Click="OnBrowseClick"/>
                        <CheckBox x:Name="SubfoldersCheck" Grid.Column="2" Content="Subfolders"
                                  Margin="10,0,0,0"/>
                        <Button Grid.Column="3" Content="Add" Style="{StaticResource AccentButton}"
                                Margin="8,0,0,0" Click="OnAddFolderClick"/>
                    </Grid>

                    <Border Grid.Row="2" Background="#FF11151A" BorderBrush="{StaticResource PanelBorder}"
                            BorderThickness="1" CornerRadius="4">
                        <ListBox x:Name="FoldersList" Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource Fg}" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Path}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="incl. subfolders" FontSize="11"
                                                       Foreground="{StaticResource FgDim}"
                                                       Visibility="{Binding IncludeSubdirectories,
                                                           Converter={StaticResource BoolToVisibility}}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Remove" Padding="8,2"
                                                Tag="{Binding}" Click="OnRemoveFolderClick"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <WrapPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Scan now" Click="OnScanNowClick"/>
                        <CheckBox x:Name="SoundCheck" Content="Sound on detection" Margin="16,0,0,0"
                                  IsChecked="True" Checked="OnSoundToggle" Unchecked="OnSoundToggle"/>
                        <CheckBox x:Name="MhrCheck" Content="Check new files via Team Cymru MHR (DNS, no key)"
                                  Margin="16,0,0,0" Checked="OnMhrToggle" Unchecked="OnMhrToggle"/>
                    </WrapPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Журнал обнаружений -->
        <Border Grid.Row="2" Background="{StaticResource Panel}" BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Detected vulnerable drivers" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ListView x:Name="DetectionsList" Grid.Row="1" Background="#FF11151A" BorderThickness="0"
                          Foreground="{StaticResource Fg}" MouseDoubleClick="OnDetectionDoubleClick">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Time" Width="150" DisplayMemberBinding="{Binding TimeText}"/>
                            <GridViewColumn Header="Source" Width="170" DisplayMemberBinding="{Binding Source}"/>
                            <GridViewColumn Header="Match" Width="220" DisplayMemberBinding="{Binding DriverName}"/>
                            <GridViewColumn Header="File" Width="160" DisplayMemberBinding="{Binding FileName}"/>
                            <GridViewColumn Header="Path" Width="320" DisplayMemberBinding="{Binding FilePath}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="Check file…" Style="{StaticResource AccentButton}" Click="OnCheckFileClick"/>
                    <Button Content="Open folder" Margin="8,0,0,0" Click="OnOpenFolderClick"/>
                    <Button Content="Copy SHA-256" Margin="8,0,0,0" Click="OnCopyHashClick"/>
                    <Button Content="Clear log" Margin="8,0,0,0" Click="OnClearLogClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Нижняя строка состояния -->
        <Border Grid.Row="3" Margin="0,12,0,0">
            <TextBlock x:Name="StatusBarText" Foreground="{StaticResource FgDim}"
                       Text="Ready" TextTrimming="CharacterEllipsis"/>
        </Border>
    </Grid>
</Window>
